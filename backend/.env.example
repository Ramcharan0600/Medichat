# # Server Configuration
# PORT=8888

# # MongoDB Connection String (Get from MongoDB Atlas)
# # Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/calmcure_lpu
# MONGO_URI=your_mongodb_connection_uri

# # JWT Secret for Token Authentication
# # Generate a long random string (e.g., using 'openssl rand -base64 32')
# JWT_SECRET=your_jwt_secret_key

# # AI Assistant API Key (Gemini API Key)
# # Get it from https://aistudio.google.com/
# OPENAI_API_KEY=your_gemini_api_key